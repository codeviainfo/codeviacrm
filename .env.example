# Base de datos
POSTGRES_USER=codevia
POSTGRES_PASSWORD=codevia
POSTGRES_DB=codevia_crm

# Backend
JWT_SECRET=cambia-este-valor-por-uno-seguro
GOOGLE_PLACES_API_KEY=

# Usuario admin sembrado al iniciar (cámbialo tras el primer login)
SEED_ADMIN_EMAIL=admin@codevia.com
SEED_ADMIN_PASSWORD=codevia123

# Canva (Connect API — Módulo de Contenido/Diseño)
# La URI de redirección debe registrarse EXACTA en el Canva Developer Portal.
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=http://localhost:4000/api/canva/callback

# URL pública del frontend — usada por el callback de Canva para rebotar
# al navegador tras completar la conexión OAuth.
FRONTEND_URL=http://localhost:5173

# Frontend
VITE_API_URL=http://localhost:4000/api
