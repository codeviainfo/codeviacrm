generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

enum ClientStatus {
  lead
  prospect
  client
  inactive
  archived
}

enum ClientSource {
  manual
  google_maps
}

model Client {
  id            String        @id @default(uuid())
  name          String
  businessName  String?
  category      String?
  phone         String?
  email         String?
  address       String?
  city          String?
  zone          String?
  notes         String?
  status        ClientStatus  @default(lead)
  source        ClientSource  @default(manual)
  googlePlaceId String?       @unique
  rating        Float?
  website       String?
  latitude      Float?
  longitude     Float?
  googleMapsUrl String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  appointments  Appointment[]
  services      Service[]

  @@index([status])
  @@index([category])
  @@index([zone])
}

enum ServiceStatus {
  pending
  completed
  invoiced
}

model Service {
  id          String        @id @default(uuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  quantity    Float         @default(1)
  unitPrice   Float
  status      ServiceStatus @default(pending)
  date        DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([clientId])
  @@index([status])
}

enum AppointmentStatus {
  pending
  confirmed
  completed
  cancelled
}

model Appointment {
  id              String            @id @default(uuid())
  clientId        String
  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  scheduledAt     DateTime
  durationMinutes Int               @default(30)
  status          AppointmentStatus @default(pending)
  createdAt       DateTime          @default(now())

  @@index([scheduledAt])
}

enum ScrapeJobStatus {
  pending
  running
  completed
  failed
}

model ScrapeJob {
  id            String            @id @default(uuid())
  zone          String
  category      String
  status        ScrapeJobStatus   @default(pending)
  source        String?
  resultsCount  Int               @default(0)
  errorMessage  String?
  createdAt     DateTime          @default(now())
  candidates    ScrapeCandidate[]
}

// Anonymous analytics session from the public landing (codeviaesp.com).
// `id` is generated client-side (crypto.randomUUID) so events can be sent
// fire-and-forget without waiting for a server response. No IP is stored,
// only the country derived from it.
model WebSession {
  id          String     @id
  country     String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  device      String?
  language    String?
  startedAt   DateTime   @default(now())
  lastSeenAt  DateTime   @default(now())
  events      WebEvent[]

  @@index([startedAt])
  @@index([country])
}

model WebEvent {
  id        String     @id @default(uuid())
  sessionId String
  session   WebSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String
  name      String?
  path      String?
  createdAt DateTime   @default(now())

  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
}

enum CandidateStatus {
  pending
  accepted
  rejected
}

// Staging row for a business found by a scrape run, before the user
// reviews it and decides whether to promote it to a Client (status=lead).
model ScrapeCandidate {
  id            String          @id @default(uuid())
  jobId         String
  job           ScrapeJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name          String
  businessName  String?
  category      String?
  phone         String?
  address       String?
  zone          String?
  rating        Float?
  website       String?
  hasWebsite    Boolean         @default(false)
  latitude      Float?
  longitude     Float?
  googlePlaceId String?
  googleMapsUrl String?
  status        CandidateStatus @default(pending)
  clientId      String?
  createdAt     DateTime        @default(now())

  @@index([jobId])
  @@index([status])
  @@index([hasWebsite])
}

// Conexión única (singleton) de la app de Canva del CRM — no por-usuario,
// coherente con que este CRM no es multi-tenant y las plantillas de marca
// son un activo de la organización, no personal.
model CanvaConnection {
  id                String   @id @default(uuid())
  accessToken       String
  refreshToken      String
  tokenType         String   @default("Bearer")
  scope             String
  expiresAt         DateTime
  connectedByUserId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Puente transitorio entre el redirect de autorización y el callback: el
// code_verifier de PKCE debe vivir solo en el servidor (nunca en el
// navegador), indexado por `state`. Se borra inmediatamente tras usarse
// (un solo uso).
model CanvaOAuthState {
  id            String   @id @default(uuid())
  state         String   @unique
  codeVerifier  String
  redirectAfter String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

enum BrandTemplateCategory {
  flyer
  social_post
  banner
}

// Una plantilla de marca de Canva registrada para su uso en este módulo.
// El registro es manual (se pega el brand_template_id desde Canva); se
// cachea aquí el esquema de campos rellenables (dataset API) para no
// llamar a Canva en cada carga de página.
model BrandTemplate {
  id              String                @id @default(uuid())
  canvaTemplateId String                @unique
  name            String
  category        BrandTemplateCategory
  thumbnailUrl    String?
  fieldSchema     Json
  active          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  designs         Design[]

  @@index([category])
  @@index([active])
}

enum DesignStatus {
  pending
  success
  failed
}

// Una instancia de diseño generado (un job de autofill -> un diseño en Canva).
model Design {
  id              String        @id @default(uuid())
  brandTemplateId String
  brandTemplate   BrandTemplate @relation(fields: [brandTemplateId], references: [id], onDelete: Cascade)
  title           String?
  status          DesignStatus  @default(pending)
  canvaJobId      String
  canvaDesignId   String?
  editUrl         String?
  thumbnailUrl    String?
  exportedFileUrl String?
  exportFormat    String?
  errorMessage    String?
  createdByUserId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([brandTemplateId])
  @@index([status])
  @@index([createdAt])
}
